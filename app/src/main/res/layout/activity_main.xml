<!-- Root -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Map container -->
    <FrameLayout
        android:id="@+id/map_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Container for floating buttons -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- 📍 My Location floating button -->
        <FrameLayout
            android:id="@+id/btn_my_location"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="bottom|end"
            android:layout_margin="16dp"
            android:background="@drawable/button_background"
            android:elevation="8dp"
            android:padding="8dp">

            <ImageButton
                android:id="@+id/btn_my_location_inner"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:padding="12dp"
                android:src="@drawable/ic_my_location" />
        </FrameLayout>

    </FrameLayout>

    <!-- 🟢 Wrap navbar + dropdown in ConstraintLayout -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/search_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:padding="10dp"
        android:elevation="20dp"
        android:translationZ="20dp">

        <!-- Logo -->
        <FrameLayout
            android:id="@+id/logo"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/button_background"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="@+id/search_bar">

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_logo"/>
        </FrameLayout>

        <!-- 🔍 Search bar -->
        <EditText
            android:id="@+id/search_bar"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:hint="Search"
            android:textColor="#FFFFFF"
            android:textColorHint="#B3FFFFFF"
            android:background="@drawable/search_bar_bg"
            android:padding="8dp"
            app:layout_constraintStart_toEndOf="@id/logo"
            app:layout_constraintEnd_toStartOf="@id/settings_button"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginHorizontal="8dp"/>

        <!-- ⚙️ Settings -->
        <FrameLayout
            android:id="@+id/settings_button"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/button_background"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/search_bar">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_settings"/>
        </FrameLayout>

        <!-- 🟢 Dropdown below search bar -->
        <ListView
            android:id="@+id/search_results_list"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/search_bar"
            app:layout_constraintStart_toStartOf="@id/search_bar"
            app:layout_constraintEnd_toEndOf="@id/search_bar"
            android:background="@drawable/search_bar_list"
            android:divider="@android:color/transparent"
            android:dividerHeight="8dp"
            android:elevation="30dp"
            android:padding="8dp"
            android:visibility="gone"
            android:clipToPadding="false"
            android:clipChildren="false"
            android:translationZ="30dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Bottom sheet -->
    <LinearLayout
        android:id="@+id/bottom_sheet"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:translationZ="40dp"
        android:background="@android:color/transparent"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <!-- Drag handle -->
        <View
            android:id="@+id/drag_handle"
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_marginTop="8dp"
            android:layout_gravity="center_horizontal"
            android:background="@color/handleColor"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bottom sheet content"
            android:padding="16dp"/>
    </LinearLayout>


</androidx.coordinatorlayout.widget.CoordinatorLayout>
